# 模型配置
# 设置为 'true' 使用改进的 ResNet 模型（69.44% 准确率）
# 设置为 'false' 使用原始的 4 个独立 ResNet 模型
USE_IMPROVED_RESNET=false

# 改进模型路径
IMPROVED_RESNET_PATH=checkpoints/improved_resnet/full_model/best_model.pth

# 原始模型路径（当 USE_IMPROVED_RESNET=false 时使用）
# RESNET_PATHS=weights/tongue_color.pth,weights/tongue_coat_color.pth,weights/thickness.pth,weights/rot_and_greasy.pth
